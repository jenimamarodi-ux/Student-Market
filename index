export default function App() {
  // === STATE UTAMA ===
  const [currentUser, setCurrentUser] = useState(null); // format: { name, username, role, balance, favorites: [] }
  const [isRegistering, setIsRegistering] = useState(false);
  const [products, setProducts] = useState(DEFAULT_PRODUCTS);
  const [orders, setOrders] = useState([
    {
      id: "ORD-9821",
      buyer: "Andi Siswa",
      items: [{ id: 1, name: "Donat Gula Halus", price: 3000, qty: 3 }],
      total: 9000,
      paymentMethod: "COD",
      status: "Menunggu Konfirmasi",
      sellerId: "penjual1",
      date: "10 Juni 2026",
      reviewed: false
    }
  ]);

  // === PENGATURAN TAMPILAN & BACKGROUND (ADMIN CONTROLLED) ===
  const [appSettings, setAppSettings] = useState({
    logoText: "Student Market Sekolah",
    logoSub: "Kreativitas Siswa Mandiri",
    headerBg: "bg-blue-700", // bg-blue-700, bg-emerald-700, bg-rose-700, bg-violet-700
    heroTitle: "Temukan Karya Terbaik Siswa!",
    heroSub: "Temukan makanan sehat, minuman segar, dan kerajinan tangan aesthetic buatan teman-teman kreatif sekolah kita!",
    heroBgGrad: "from-blue-700 via-blue-600 to-amber-400", // gradient classes
    appWallpaper: "grid-notebook", // standard, grid-notebook, dots-aesthetic, amber-semangat, blue-lembut, kustom-link
    customWallpaperUrl: ""
  });

  // Form Login & Registrasi
  const [loginForm, setLoginForm] = useState({ username: '', password: '' });
  const [regForm, setRegForm] = useState({ name: '', username: '', password: '', role: 'Pembeli' });

  // Navigasi & Filter Aplikasi
  const [activeTab, setActiveTab] = useState('Beranda'); // Beranda, Cari, Keranjang, Pesanan, Profil, PenjualDashboard, AdminDashboard
  const [sellerSubTab, setSellerSubTab] = useState('Kelola'); // Kelola, Tambah, Pesanan, Laporan
  const [adminSubTab, setAdminSubTab] = useState('Tampilan'); // Tampilan, ProdukGambar, LandingPage
  
  // Filter & Pencarian
  const [searchTerm, setSearchTerm] = useState('');
  const [selectedCategory, setSelectedCategory] = useState('Semua');
  const [maxPrice, setMaxPrice] = useState(100000);

  // Keranjang Belanja
  const [cart, setCart] = useState([]);

  // Detail/Review Modal
  const [selectedProduct, setSelectedProduct] = useState(null);
  const [reviewRating, setReviewRating] = useState(5);
  const [reviewComment, setReviewComment] = useState('');

  // Form Tambah/Edit Produk Penjual
  const [isEditing, setIsEditing] = useState(false);
  const [productForm, setProductForm] = useState({
    id: null,
    name: '',
    category: 'Makanan',
    description: '',
    price: '',
    stock: '',
    image: '',
    promo: false
  });

  // Notifikasi Custom (Toast)
  const [toast, setToast] = useState(null);

  const showToast = (message, type = 'success') => {
    setToast({ message, type });
    setTimeout(() => {
      setToast(null);
    }, 3000);
  };

  // === SISTEM AUTENTIKASI ===
  const handleLogin = (e) => {
    e.preventDefault();
    if (!loginForm.username || !loginForm.password) {
      showToast("Harap isi semua kolom login!", "error");
      return;
    }

    let role = 'Pembeli';
    let name = loginForm.username;

    if (loginForm.username === 'admin') {
      role = 'Admin';
      name = 'Admin Utama Sekolah';
    } else if (loginForm.username === 'penjual') {
      role = 'Penjual';
      name = 'Pak Eko (Kantin)';
    } else if (loginForm.username === 'pembeli') {
      role = 'Pembeli';
      name = 'Andi Siswa';
    }

    const mockUser = {
      name: name,
      username: loginForm.username,
      role: role,
      balance: role === 'Penjual' ? 250000 : role === 'Admin' ? 1000000 : 75000,
      favorites: [1, 3],
      avatar: "https://api.dicebear.com/7.x/adventurer/svg?seed=" + loginForm.username
    };

    setCurrentUser(mockUser);
    showToast(`Selamat datang kembali, ${mockUser.name}!`, "success");
    
    if (mockUser.role === 'Penjual') {
      setActiveTab('PenjualDashboard');
      setSellerSubTab('Kelola');
    } else if (mockUser.role === 'Admin') {
      setActiveTab('AdminDashboard');
      setAdminSubTab('Tampilan');
    } else {
      setActiveTab('Beranda');
    }
  };

  const handleRegister = (e) => {
    e.preventDefault();
    if (!regForm.name || !regForm.username || !regForm.password) {
      showToast("Harap isi semua kolom pendaftaran!", "error");
      return;
    }

    const newUser = {
      name: regForm.name,
      username: regForm.username,
      role: regForm.role,
      balance: regForm.role === 'Penjual' ? 0 : regForm.role === 'Admin' ? 500000 : 50000,
      favorites: [],
      avatar: "https://api.dicebear.com/7.x/adventurer/svg?seed=" + regForm.username
    };

    setCurrentUser(newUser);
    showToast("Akun berhasil didaftarkan!", "success");
    
    if (newUser.role === 'Penjual') {
      setActiveTab('PenjualDashboard');
      setSellerSubTab('Kelola');
    } else if (newUser.role === 'Admin') {
      setActiveTab('AdminDashboard');
      setAdminSubTab('Tampilan');
    } else {
      setActiveTab('Beranda');
    }
    setIsRegistering(false);
  };

  const handleLogout = () => {
    setCurrentUser(null);
    setCart([]);
    showToast("Anda telah keluar akun", "info");
  };

  // === FITUR FAVORIT & KERANJANG ===
  const toggleFavorite = (productId) => {
    if (!currentUser) return;
    let updatedFavorites = [...currentUser.favorites];
    if (updatedFavorites.includes(productId)) {
      updatedFavorites = updatedFavorites.filter(id => id !== productId);
      showToast("Dihapus dari Favorit", "info");
    } else {
      updatedFavorites.push(productId);
      showToast("Ditambahkan ke Favorit!", "success");
    }
    setCurrentUser({ ...currentUser, favorites: updatedFavorites });
  };

  const addToCart = (product) => {
    if (product.stock <= 0) {
      showToast("Stok produk habis!", "error");
      return;
    }
    const existingIndex = cart.findIndex(item => item.id === product.id);
    if (existingIndex > -1) {
      const updatedCart = [...cart];
      if (updatedCart[existingIndex].qty >= product.stock) {
        showToast("Jumlah melebihi stok yang tersedia!", "error");
        return;
      }
      updatedCart[existingIndex].qty += 1;
      setCart(updatedCart);
    } else {
      setCart([...cart, { ...product, qty: 1 }]);
    }
    showToast(`${product.name} dimasukkan ke keranjang`, "success");
  };

  const updateCartQty = (productId, amount) => {
    const updatedCart = cart.map(item => {
      if (item.id === productId) {
        const newQty = item.qty + amount;
        const originalProduct = products.find(p => p.id === productId);
        if (newQty <= 0) return null;
        if (originalProduct && newQty > originalProduct.stock) {
          showToast("Stok tidak mencukupi!", "error");
          return item;
        }
        return { ...item, qty: newQty };
      }
      return item;
    }).filter(Boolean);
    setCart(updatedCart);
  };

  const removeFromCart = (productId) => {
    setCart(cart.filter(item => item.id !== productId));
    showToast("Produk dihapus dari keranjang", "info");
  };

  const cartTotal = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);

  // === TRANSAKSI & CHECKOUT ===
  const handleCheckout = (paymentMethod) => {
    if (cart.length === 0) return;
    if (currentUser.balance < cartTotal && (paymentMethod === 'Transfer Bank' || paymentMethod === 'QRIS')) {
      showToast("Saldo digital Anda tidak mencukupi!", "error");
      return;
    }

    const orderId = "ORD-" + Math.floor(1000 + Math.random() * 9000);
    const newOrder = {
      id: orderId,
      buyer: currentUser.name,
      items: [...cart],
      total: cartTotal,
      paymentMethod: paymentMethod,
      status: "Menunggu Konfirmasi",
      sellerId: "penjual1", 
      date: "Hari Ini",
      reviewed: false
    };

    const updatedProducts = products.map(p => {
      const cartItem = cart.find(c => c.id === p.id);
      if (cartItem) {
        return { ...p, stock: p.stock - cartItem.qty, sold: p.sold + cartItem.qty };
      }
      return p;
    });

    setProducts(updatedProducts);
    setOrders([newOrder, ...orders]);
    
    if (paymentMethod === 'Transfer Bank' || paymentMethod === 'QRIS') {
      setCurrentUser({ ...currentUser, balance: currentUser.balance - cartTotal });
    }

    setCart([]);
    showToast("Pesanan berhasil dibuat! Menunggu konfirmasi.", "success");
    setActiveTab('Pesanan');
  };

  // === FITUR PRODUK UNTUK PENJUAL ===
  const handleSaveProduct = (e) => {
    e.preventDefault();
    if (!productForm.name || !productForm.price || !productForm.stock) {
      showToast("Harap isi nama, harga, dan stok!", "error");
      return;
    }

    const priceNum = parseInt(productForm.price);
    const stockNum = parseInt(productForm.stock);
    const defaultImg = "https://images.unsplash.com/photo-1542838132-92c53300491e?w=500&auto=format&fit=crop&q=60";

    if (isEditing) {
      const updated = products.map(p => {
        if (p.id === productForm.id) {
          return {
            ...p,
            name: productForm.name,
            category: productForm.category,
            description: productForm.description || 'Tidak ada deskripsi.',
            price: priceNum,
            stock: stockNum,
            image: productForm.image || defaultImg,
            promo: productForm.promo
          };
        }
        return p;
      });
      setProducts(updated);
      showToast("Produk berhasil diperbarui!", "success");
      setIsEditing(false);
    } else {
      const newProduct = {
        id: Date.now(),
        name: productForm.name,
        category: productForm.category,
        description: productForm.description || 'Tidak ada deskripsi.',
        price: priceNum,
        stock: stockNum,
        sold: 0,
        rating: 5.0,
        reviews: [],
        image: productForm.image || defaultImg,
        promo: productForm.promo,
        sellerId: "penjual1"
      };
      setProducts([newProduct, ...products]);
      showToast("Produk baru berhasil diunggah!", "success");
    }

    setProductForm({
      id: null,
      name: '',
      category: 'Makanan',
      description: '',
      price: '',
      stock: '',
      image: '',
      promo: false
    });
    setSellerSubTab('Kelola');
  };

  const handleEditProductClick = (product) => {
    setIsEditing(true);
    setProductForm({
      id: product.id,
      name: product.name,
      category: product.category,
      description: product.description,
      price: product.price.toString(),
      stock: product.stock.toString(),
      image: product.image,
      promo: product.promo
    });
    setSellerSubTab('Tambah');
  };

  const handleDeleteProduct = (productId) => {
    setProducts(products.filter(p => p.id !== productId));
    showToast("Produk berhasil dihapus!", "info");
  };

  const handleUpdateOrderStatus = (orderId, newStatus) => {
    const updated = orders.map(ord => {
      if (ord.id === orderId) {
        return { ...ord, status: newStatus };
      }
      return ord;
    });
    setOrders(updated);
    showToast(`Pesanan ${orderId} berstatus: ${newStatus}`, "success");
  };

  // === FITUR EDIT FOTO PRODUK (UNTUK ADMIN) ===
  const handleUpdateProductImage = (productId, newImageUrl) => {
    if (!newImageUrl.trim()) {
      showToast("URL gambar tidak boleh kosong!", "error");
      return;
    }
    const updated = products.map(p => {
      if (p.id === productId) {
        return { ...p, image: newImageUrl };
      }
      return p;
    });
    setProducts(updated);
    showToast("Foto produk berhasil diperbarui!", "success");
  };

  // === FITUR ULASAN ===
  const handleSubmitReview = (e, orderId, productId) => {
    e.preventDefault();
    if (!reviewComment.trim()) {
      showToast("Tulis komentar ulasan Anda terlebih dahulu!", "error");
      return;
    }

    const updatedProducts = products.map(p => {
      if (p.id === productId) {
        const newReviews = [...p.reviews, { user: currentUser.name, rating: reviewRating, comment: reviewComment }];
        const avgRating = parseFloat((newReviews.reduce((sum, r) => sum + r.rating, 0) / newReviews.length).toFixed(1));
        return { ...p, reviews: newReviews, rating: avgRating };
      }
      return p;
    });

    const updatedOrders = orders.map(o => {
      if (o.id === orderId) {
        return { ...o, reviewed: true };
      }
      return o;
    });

    setProducts(updatedProducts);
    setOrders(updatedOrders);
    setReviewComment('');
    setSelectedProduct(null);
    showToast("Terima kasih atas ulasan Anda!", "success");
  };

  // === GET WALLPAPER STYLES ===
  const getWallpaperClass = () => {
    switch (appSettings.appWallpaper) {
      case "grid-notebook":
        return "bg-slate-50 [background-image:linear-gradient(to_right,#e2e8f0_1px,transparent_1px),linear-gradient(to_bottom,#e2e8f0_1px,transparent_1px)] [background-size:24px_24px]";
      case "dots-aesthetic":
        return "bg-slate-50 [background-image:radial-gradient(#cbd5e1_1px,transparent_1px)] [background-size:16px_16px]";
      case "amber-semangat":
        return "bg-amber-50/60";
      case "blue-lembut":
        return "bg-sky-50/60";
      case "kustom-link":
        return "bg-slate-100 bg-cover bg-center bg-no-attachment";
      default:
        return "bg-slate-50";
    }
  };

  const getWallpaperInlineStyle = () => {
    if (appSettings.appWallpaper === "kustom-link" && appSettings.customWallpaperUrl) {
      return { backgroundImage: `url(${appSettings.customWallpaperUrl})`, backgroundAttachment: 'fixed' };
    }
    return {};
  };

  // === FILTERING PRODUK ===
  const filteredProducts = products.filter(product => {
    const matchesSearch = product.name.toLowerCase().includes(searchTerm.toLowerCase()) || 
                          product.description.toLowerCase().includes(searchTerm.toLowerCase());
    const matchesCategory = selectedCategory === 'Semua' || product.category === selectedCategory;
    const matchesPrice = product.price <= maxPrice;
    return matchesSearch && matchesCategory && matchesPrice;
  });

  // Statistik Keuangan
  const totalRevenue = orders
    .filter(o => o.status === 'Selesai')
    .reduce((sum, o) => sum + o.total, 0);

  const totalItemsSold = orders
    .filter(o => o.status === 'Selesai')
    .reduce((sum, o) => sum + o.items.reduce((iSum, item) => iSum + item.qty, 0), 0);

  const bestSellingProduct = [...products].sort((a, b) => b.sold - a.sold)[0];

  return (
    <div 
      className={`min-h-screen text-slate-800 font-sans flex flex-col transition-all duration-300 ${getWallpaperClass()}`}
      style={getWallpaperInlineStyle()}
    >
      
      {/* Toast Notification */}
      {toast && (
        <div className={`fixed top-4 right-4 z-50 flex items-center p-4 rounded-lg shadow-xl text-white transition-all duration-300 ${
          toast.type === 'success' ? 'bg-emerald-600' : toast.type === 'error' ? 'bg-rose-600' : 'bg-blue-600'
        }`}>
          <span className="font-semibold">{toast.message}</span>
        </div>
      )}

      {/* HEADER UTAMA */}
      <header className={`${appSettings.headerBg} text-white shadow-md sticky top-0 z-40 transition-colors duration-300`}>
        <div className="max-w-6xl mx-auto px-4 py-3 flex justify-between items-center">
          <div className="flex items-center space-x-3 cursor-pointer" onClick={() => setActiveTab('Beranda')}>
            <div className="bg-amber-400 p-2 rounded-lg text-blue-900 font-bold flex items-center justify-center shadow-inner">
              <Store size={24} />
            </div>
            <div>
              <h1 className="font-extrabold text-xl tracking-tight leading-none">{appSettings.logoText}</h1>
              <span className="text-xs text-blue-100 font-medium">{appSettings.logoSub}</span>
            </div>
          </div>

          {currentUser ? (
            <div className="flex items-center space-x-4">
              <div className="hidden md:flex flex-col text-right">
                <span className="font-semibold text-sm">{currentUser.name}</span>
                <span className="text-xs bg-amber-400 text-blue-950 px-2 py-0.5 rounded-full font-bold self-end mt-0.5">
                  {currentUser.role}
                </span>
              </div>
              <img 
                src={currentUser.avatar} 
                alt="Avatar" 
                className="w-10 h-10 rounded-full border-2 border-amber-400 bg-white cursor-pointer"
                onClick={() => {
                  if (currentUser.role === 'Admin') setActiveTab('AdminDashboard');
                  else if (currentUser.role === 'Penjual') setActiveTab('PenjualDashboard');
                  else setActiveTab('Profil');
                }}
              />
              <button 
                onClick={handleLogout}
                className="p-1.5 bg-black/20 hover:bg-rose-700 transition rounded-lg text-white"
                title="Keluar Akun"
              >
                <LogOut size={18} />
              </button>
