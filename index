                      <div className="grid grid-cols-2 sm:grid-cols-4 gap-2.5 pt-2">
                        {[
                          { id: 'bg-blue-700', name: 'Biru Pendidikan', color: 'bg-blue-700' },
                          { id: 'bg-emerald-700', name: 'Hijau Koperasi', color: 'bg-emerald-700' },
                          { id: 'bg-rose-700', name: 'Merah Semangat', color: 'bg-rose-700' },
                          { id: 'bg-violet-700', name: 'Ungu Kreatif', color: 'bg-violet-700' }
                        ].map((bg) => (
                          <button
                            key={bg.id}
                            onClick={() => {
                              setAppSettings({...appSettings, headerBg: bg.id});
                              showToast(`Warna header diubah ke ${bg.name}`, 'success');
                            }}
                            className={`p-2.5 rounded-xl border text-left flex items-center space-x-2.5 transition ${
                              appSettings.headerBg === bg.id ? 'border-rose-600 bg-slate-50 shadow-inner' : 'border-slate-200 hover:border-slate-300'
                            }`}
                          >
                            <span className={`w-5 h-5 rounded-full ${bg.color} block border`}></span>
                            <span className="text-xs font-bold text-slate-700">{bg.name}</span>
                          </button>
                        ))}
                      </div>
                    </div>
                  </div>
                )}

                {/* 2. GANTI GAMBAR PRODUK SECARA INTERAKTIF */}
                {adminSubTab === 'ProdukGambar' && (
                  <div className="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm space-y-6 animate-in fade-in slide-in-from-bottom-3 duration-300">
                    <div>
                      <h4 className="font-extrabold text-slate-800 text-lg flex items-center">
                        <LucideImage className="text-rose-500 mr-2" size={20} />
                        Ganti Gambar & Foto Produk Realtime
                      </h4>
                      <p className="text-xs text-slate-400 mt-1">Ubah gambar produk apa saja menggunakan link eksternal atau manfaatkan pustaka foto instan di bawah ini.</p>
                    </div>

                    {/* Preset Gambar Cepat */}
                    <div className="bg-slate-50 p-4 rounded-2xl border border-slate-200">
                      <span className="text-xs font-extrabold text-slate-600 block mb-3 uppercase tracking-wider flex items-center">
                        <Sparkles className="text-amber-500 mr-1.5" size={14} />
                        Pustaka Foto Instan (Cukup Tarik & Klik)
                      </span>
                      <div className="grid grid-cols-3 sm:grid-cols-6 gap-2.5">
                        {PRESET_IMAGES.map((preset, index) => (
                          <div 
                            key={index} 
                            className="bg-white p-1 rounded-xl border border-slate-100 flex flex-col items-center hover:shadow-md transition duration-200"
                          >
                            <img src={preset.url} alt={preset.name} className="w-full h-14 object-cover rounded-lg" />
                            <span className="text-[9px] font-bold text-slate-500 mt-1.5 text-center truncate w-full">{preset.name}</span>
                            <button
                              onClick={() => {
                                // Salin URL ke clipboard buatan / simulasi
                                navigator.clipboard.writeText(preset.url);
                                showToast(`URL "${preset.name}" disalin! Tempel di input produk pilihanmu.`, 'info');
                              }}
                              className="mt-1 w-full text-[8px] bg-rose-50 text-rose-700 font-extrabold py-0.5 rounded uppercase hover:bg-rose-100 transition"
                            >
                              Salin URL
                            </button>
                          </div>
                        ))}
                      </div>
                    </div>

                    {/* Form Daftar Edit Gambar per Produk */}
                    <div className="space-y-4">
                      <span className="text-xs font-bold text-slate-500 block uppercase">Daftar Produk Jualan</span>
                      
                      <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                        {products.map((prod) => (
                          <div 
                            key={prod.id} 
                            className="border border-slate-100 rounded-2xl p-4 flex flex-col bg-slate-50/50 hover:bg-white transition-colors duration-200"
                          >
                            <div className="flex items-center space-x-3 mb-3">
                              <img src={prod.image} alt={prod.name} className="w-14 h-14 object-cover rounded-xl border shadow-inner" />
                              <div className="min-w-0">
                                <span className="text-[9px] bg-rose-100 text-rose-800 font-extrabold px-2 py-0.5 rounded-full">{prod.category}</span>
                                <h5 className="font-bold text-slate-800 text-sm truncate mt-1">{prod.name}</h5>
                                <p className="text-xs text-blue-600 font-extrabold">Rp {prod.price.toLocaleString('id-ID')}</p>
                              </div>
                            </div>

                            <div className="space-y-2">
                              <label className="block text-[10px] font-extrabold text-slate-400 uppercase tracking-wider">Tautan Gambar (Link/URL)</label>
                              <div className="flex gap-2">
                                <input 
                                  type="text"
                                  defaultValue={prod.image}
                                  id={`img-url-${prod.id}`}
                                  placeholder="Masukkan URL foto baru"
                                  className="flex-1 px-3 py-2 rounded-xl border border-slate-200 text-xs bg-white focus:outline-none focus:ring-1 focus:ring-rose-500"
                                />
                                <button
                                  onClick={() => {
                                    const inputVal = document.getElementById(`img-url-${prod.id}`).value;
                                    handleUpdateProductImage(prod.id, inputVal);
                                  }}
                                  className="px-3.5 py-2 bg-rose-600 hover:bg-rose-700 text-white font-extrabold text-xs rounded-xl transition"
                                >
                                  Simpan
                                </button>
                              </div>
                            </div>

                            {/* Tombol rekomendasi cepat khusus produk ini */}
                            <div className="mt-3 pt-2.5 border-t border-slate-100 flex items-center justify-between">
                              <span className="text-[9px] text-slate-400 font-semibold">Terapkan Foto Cepat:</span>
                              <div className="flex gap-1">
                                {PRESET_IMAGES.slice(0, 4).map((p, i) => (
                                  <button
                                    key={i}
                                    onClick={() => {
                                      handleUpdateProductImage(prod.id, p.url);
                                      document.getElementById(`img-url-${prod.id}`).value = p.url;
                                    }}
                                    className="px-2 py-0.5 bg-white border border-slate-200 hover:border-rose-500 hover:text-rose-600 rounded text-[9px] font-extrabold text-slate-600 transition"
                                  >
                                    {p.name.split(' ')[0]}
                                  </button>
                                ))}
                              </div>
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>
                )}

                {/* 3. EDIT LANDING PAGE */}
                {adminSubTab === 'LandingPage' && (
                  <div className="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm space-y-6 animate-in fade-in slide-in-from-bottom-3 duration-300">
                    <h4 className="font-extrabold text-slate-800 text-lg flex items-center">
                      <Layout className="text-rose-500 mr-2" size={20} />
                      Konfigurasi Landing Page & Banner
                    </h4>

                    <div className="space-y-4">
                      <div>
                        <label className="block text-xs font-bold uppercase text-slate-500 mb-1">Judul Banner Sambutan</label>
                        <input 
                          type="text" 
                          value={appSettings.heroTitle}
                          onChange={(e) => setAppSettings({...appSettings, heroTitle: e.target.value})}
                          className="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-sm focus:ring-2 focus:ring-rose-500 bg-white"
                        />
                      </div>

                      <div>
                        <label className="block text-xs font-bold uppercase text-slate-500 mb-1">Deskripsi & Motivasi Siswa</label>
                        <textarea 
                          rows="3"
                          value={appSettings.heroSub}
                          onChange={(e) => setAppSettings({...appSettings, heroSub: e.target.value})}
                          className="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-sm focus:ring-2 focus:ring-rose-500 bg-white"
                        ></textarea>
                      </div>

                      <div>
                        <label className="block text-xs font-bold uppercase text-slate-500 mb-2">Gradasi Warna Banner Sambutan</label>
                        <div className="grid grid-cols-1 sm:grid-cols-2 gap-3">
                          {[
                            { id: 'from-blue-700 via-blue-600 to-amber-400', name: 'Biru Sekolah ke Kuning Kreatif', style: 'bg-gradient-to-r from-blue-700 via-blue-600 to-amber-400' },
                            { id: 'from-emerald-700 to-teal-500', name: 'Hijau Alami Terang', style: 'bg-gradient-to-r from-emerald-700 to-teal-500' },
                            { id: 'from-rose-600 to-amber-500', name: 'Oranye Senja Merona', style: 'bg-gradient-to-r from-rose-600 to-amber-500' },
                            { id: 'from-purple-700 to-indigo-500', name: 'Ungu Mewah Modern', style: 'bg-gradient-to-r from-purple-700 to-indigo-500' }
                          ].map((grad) => (
                            <button
                              key={grad.id}
                              onClick={() => {
                                setAppSettings({...appSettings, heroBgGrad: grad.id});
                                showToast(`Gradasi banner diganti ke ${grad.name}`, 'success');
                              }}
                              className={`p-3 rounded-xl border text-left flex flex-col justify-between h-20 transition ${
                                appSettings.heroBgGrad === grad.id ? 'border-rose-500 ring-2 ring-rose-100 bg-rose-50/20' : 'border-slate-200 hover:border-slate-300'
                              }`}
                            >
                              <span className={`w-full h-5 rounded-md ${grad.style} block border`}></span>
                              <span className="text-[10px] font-bold text-slate-700 mt-2">{grad.name}</span>
                            </button>
                          ))}
                        </div>
                      </div>
                    </div>
                  </div>
                )}
              </div>
            )}

          </div>
        )}

      </main>

      {/* DETAIL MODAL PRODUK DAN RATING */}
      {selectedProduct && (
        <div className="fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center p-4 z-50">
          <div className="bg-white rounded-3xl max-w-lg w-full overflow-hidden shadow-2xl animate-in fade-in zoom-in-95 duration-200">
            <div className="relative">
              <img src={selectedProduct.image} alt={selectedProduct.name} className="w-full h-48 object-cover" />
              <button 
                onClick={() => setSelectedProduct(null)}
                className="absolute top-4 right-4 bg-white/90 p-2 rounded-full text-slate-700 hover:text-black shadow transition"
              >
                ✕
              </button>
            </div>

            <div className="p-6 space-y-4">
              <div>
                <span className="text-xs bg-blue-100 text-blue-700 font-extrabold px-2.5 py-0.5 rounded-full uppercase">
                  {selectedProduct.category}
                </span>
                <h3 className="font-extrabold text-xl text-slate-800 mt-1">{selectedProduct.name}</h3>
                <div className="flex items-center text-sm text-amber-500 mt-1">
                  <Star size={14} fill="currentColor" />
                  <span className="ml-1 font-bold">{selectedProduct.rating}</span>
                  <span className="text-slate-400 ml-1">({selectedProduct.reviews.length} ulasan dari siswa)</span>
                </div>
              </div>

              <div>
                <h4 className="font-bold text-xs text-slate-400 uppercase">Deskripsi</h4>
                <p className="text-slate-600 text-sm mt-1">{selectedProduct.description}</p>
              </div>

              <div className="flex justify-between items-center bg-slate-50 p-3 rounded-xl border border-slate-100">
                <div>
                  <span className="text-xs text-slate-400 block">Sisa Stok</span>
                  <span className="font-bold text-slate-800">{selectedProduct.stock} Unit</span>
                </div>
                <div>
                  <span className="text-xs text-slate-400 block text-right">Harga</span>
                  <span className="font-extrabold text-blue-700 text-lg">Rp {selectedProduct.price.toLocaleString('id-ID')}</span>
                </div>
              </div>

              {currentUser && currentUser.role === 'Pembeli' && (
                <div className="space-y-3 border-t border-slate-100 pt-3">
                  <h4 className="font-bold text-xs text-slate-400 uppercase">Beri Ulasan Kamu</h4>
                  <form onSubmit={(e) => handleSubmitReview(e, "SIMULATED-ID", selectedProduct.id)} className="space-y-3">
                    <div className="flex space-x-1.5 text-amber-400">
                      {[1, 2, 3, 4, 5].map(star => (
                        <button
                          key={star}
                          type="button"
                          onClick={() => setReviewRating(star)}
                          className="hover:scale-110 transition"
                        >
                          <Star size={20} fill={star <= reviewRating ? "currentColor" : "none"} />
                        </button>
                      ))}
                    </div>
                    <div className="flex space-x-2">
                      <input 
                        type="text"
                        placeholder="Komentar Anda"
                        value={reviewComment}
                        onChange={(e) => setReviewComment(e.target.value)}
                        className="flex-1 px-3 py-2 rounded-xl border border-slate-200 text-sm"
                      />
                      <button 
                        type="submit"
                        className="px-4 py-2 bg-blue-600 text-white font-bold text-xs rounded-xl"
                      >
                        Kirim
                      </button>
                    </div>
                  </form>
                </div>
              )}

              <div className="space-y-2 border-t border-slate-100 pt-3">
                <h4 className="font-bold text-xs text-slate-400 uppercase">Ulasan Teman</h4>
                <div className="max-h-24 overflow-y-auto space-y-2">
                  {selectedProduct.reviews.length > 0 ? (
                    selectedProduct.reviews.map((rev, index) => (
                      <div key={index} className="text-xs border-b border-slate-50 pb-2">
                        <div className="flex justify-between font-bold text-slate-700">
                          <span>{rev.user}</span>
                          <span className="text-amber-500">★ {rev.rating}</span>
                        </div>
                        <p className="text-slate-500 italic mt-0.5">"{rev.comment}"</p>
                      </div>
                    ))
                  ) : (
                    <p className="text-xs text-slate-400">Belum ada ulasan.</p>
                  )}
                </div>
              </div>

              {currentUser && currentUser.role === 'Pembeli' && (
                <button 
                  onClick={() => {
                    addToCart(selectedProduct);
                    setSelectedProduct(null);
                  }}
                  className="w-full py-3 bg-amber-400 text-blue-900 font-extrabold rounded-xl shadow"
                >
                  Tambah Ke Keranjang
                </button>
              )}
            </div>
          </div>
        </div>
      )}

      {/* FOOTER NAVIGASI */}
      {currentUser && (
        <footer className="fixed bottom-0 left-0 right-0 bg-white/95 backdrop-blur-sm border-t border-slate-200 py-2 px-4 shadow-lg z-30 md:relative md:mt-12 md:bg-transparent md:border-none md:shadow-none">
          <div className="max-w-md mx-auto md:max-w-6xl flex justify-around md:justify-end md:space-x-4 items-center">
            
            {currentUser.role === 'Pembeli' ? (
              <>
                {[
                  { id: 'Beranda', label: 'Beranda', icon: Store },
                  { id: 'Cari', label: 'Cari', icon: Search },
                  { id: 'Keranjang', label: `Keranjang (${cart.length})`, icon: ShoppingCart },
                  { id: 'Pesanan', label: 'Pesanan', icon: ClipboardList },
                  { id: 'Profil', label: 'Profil', icon: User }
                ].map((item) => {
                  const Icon = item.icon;
                  return (
                    <button
                      key={item.id}
                      onClick={() => setActiveTab(item.id)}
                      className={`flex flex-col md:flex-row items-center md:space-x-1.5 p-2 rounded-xl transition ${
                        activeTab === item.id 
                          ? 'text-blue-600 font-bold bg-blue-50 md:px-4' 
                          : 'text-slate-500 hover:text-slate-800'
                      }`}
                    >
                      <Icon size={20} />
                      <span className="text-[10px] md:text-sm mt-0.5 md:mt-0 font-semibold">{item.label}</span>
                    </button>
                  );
                })}
              </>
            ) : currentUser.role === 'Penjual' ? (
              <button
                onClick={() => setActiveTab('PenjualDashboard')}
                className="flex items-center space-x-1.5 px-4 py-2 bg-blue-600 text-white font-bold rounded-xl shadow text-xs"
              >
                <Store size={18} />
                <span>Dashboard Penjual</span>
              </button>
            ) : (
              <button
                onClick={() => setActiveTab('AdminDashboard')}
                className="flex items-center space-x-1.5 px-4 py-2 bg-rose-600 text-white font-bold rounded-xl shadow text-xs"
              >
                <Settings size={18} />
                <span>Dashboard Admin</span>
              </button>
            )}

            <span className="hidden md:inline text-xs text-slate-400 self-center">
              Student Market Sekolah © 2026. All rights reserved.
            </span>

          </div>
        </footer>
      )}

    </div>
  );
}